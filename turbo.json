{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".npmrc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "inputs": ["src/**", "*.{js,ts,cjs,json}"]
    },
    "typecheck": {
      "inputs": ["src/**", "tsconfig.json", "expo-env.d.ts", ".expo/types/**"],
      "outputs": []
    },
    "test": {
      "inputs": [
        "src/**",
        "jest.config.js",
        "jest-setup.ts",
        "jest/**",
        "package.json",
        "$TURBO_ROOT$/supabase/functions/calendar-feed/**",
        "$TURBO_ROOT$/supabase/functions/receive-booking-email/**"
      ],
      "outputs": []
    }
  }
}
