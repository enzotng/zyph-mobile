{
  "expo": {
    "name": "ZYPH",
    "slug": "zyph",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zyph",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "fr.enzotang.zyph",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "fr.enzotang.zyph",
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "backgroundColor": "#4F46E5",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "react-native-edge-to-edge",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-maps",
        {
          "requestLocationPermission": true,
          "locationPermission": "Allow ZYPH to use your location to place trip events on the map."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow ZYPH to use your location to place trip events on the map."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ZYPH to access your camera to scan expense receipts."
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "fr"
            ],
            "android": [
              "en",
              "fr"
            ]
          }
        }
      ],
      "expo-image",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ZYPH to access your photos to set your profile picture.",
          "cameraPermission": "Allow ZYPH to use your camera to take your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "577ab370-640b-49ca-a556-ce5763250d73"
      }
    },
    "owner": "smoukeuur"
  }
}
